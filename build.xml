<project name="StardateSystemTray" default="CompileAndJar" basedir=".">

	<property name="version" value="1.6" />
	<property environment="env" />

	<!-- Compile properties -->
	<property name="classes" location="classes" />
	<property name="doc" location="doc" />
	<property name="i18n" location="i18n" />
	<property name="img" location="img" />
	<property name="javadoc" value="javadoc" />
	<property name="jar-filename" value="stardate.jar" />
	<property name="applet-jar-filename" value="stardateapplet.jar" />
	<property name="application-jar-filename" value="stardateconverter.jar" />
	<property name="systemtray-jar-filename" value="stardatesystemtray.jar" />
	<property name="lib" location="lib" />
	<property name="packaging" location="packaging" />
	<property name="release" location="release" />
	<property name="src" location="src" />

	<!-- Microsoft Windows properties -->
	<property name="win32" location="packaging/win32" />

	<!-- Debian properties -->
	<property name="deb" value="packaging/debian" />
	<property name="deb-filename" value="stardatesystemtray" />


	<!-- Compile class files and JAR -->
	<target name="CompileAndJar">
		<delete dir="${classes}" />
		<mkdir dir="${classes}" />

		<delete file="${release}/${jar-filename}" />
		<delete file="${release}/${applet-jar-filename}" />
		<delete file="${release}/${application-jar-filename}" />
		<delete file="${release}/${systemtray-jar-filename}" />
		<mkdir dir="${release}" />

		<javac srcdir="${src}" destdir="${classes}">
			<classpath>
				<pathelement location="${lib}/joda-time-1.5.2.jar" />								
				<pathelement location="${lib}/win32/jRegistryKey.jar" />
			</classpath>
			<compilerarg value="-Xlint:deprecation,fallthrough,finally,path,serial,unchecked" />
		</javac>

		<copy todir="${classes}/i18n">
			<fileset dir="${i18n}"/>
		</copy>

		<copy file="${img}/stardatesystemtray16x16.gif" todir="${classes}" />
		<copy file="${img}/stardatesystemtray20x20.gif" todir="${classes}" />

		<jar jarfile="${release}/${jar-filename}" basedir="${classes}" includes="Stardate.class StardateException*.class" />

		<jar jarfile="${release}/${applet-jar-filename}" basedir="${classes}" includes="StardateApplet*.class" />

		<manifest file="${classes}/MANIFEST.MF">
			<attribute name="Class-Path" value=". ${jar-filename}" />
			<attribute name="Main-Class" value="StardateConverter" />
		</manifest>
		<jar 
			jarfile="${release}/${application-jar-filename}" 
			basedir="${classes}" 
			includes="StardateConverter.class stardatesystemtray16x16.gif" 
			manifest="${classes}/MANIFEST.MF" 
		/>

		<manifest file="${classes}/MANIFEST.MF">
			<attribute name="Class-Path" value=". ${jar-filename} joda-time-1.5.2.jar jRegistryKey.jar" />
			<attribute name="Main-Class" value="StardateSystemTray" />
		</manifest>
		<jar 
			jarfile="${release}/${systemtray-jar-filename}"
			basedir="${classes}"
			includes=" i18n/* MessageDialog.class Messages.class PopupMenu.class Properties.class ShowCalendars*.class StardateSystemTray*.class SystemStart.class TrayIcon.class stardatesystemtray16x16.gif stardatesystemtray20x20.gif"
			manifest="${classes}/MANIFEST.MF"
		/>

		<delete dir="${classes}" />
	</target>


	<!-- JavaDoc -->
	<target name="JavaDoc" description="Create Javadoc for the Stardate API.">
		<property name="windowtitle" value="Stardate v1.2 API Specification" />
		<property name="doctitle" value="Stardate v1.2 API Specification" />
		<property name="header" value="Stardate v1.2 API Specification" />
		<delete dir="${javadoc}" />
		<mkdir dir="${javadoc}" />
		<javadoc 
			sourcefiles="${src}/Stardate.java,${src}/StardateException.java" 
			packagenames="*.*" 
			destdir="${javadoc}" 
			author="true" 
			version="true" 
			use="true" 
			splitindex="true" 
			overview="${src}/overview.html" 
			windowtitle="${windowtitle}" 
			header="${header}" 
			doctitle="${doctitle}"
		>
		</javadoc>
	</target>


	<!-- Use NSIS to build Windows installer and setup executables -->
	<target name="Win32" depends="CompileAndJar" description="Build the Microsoft Windows installer and executable using NSIS.">
		<exec executable="${env.NSIS_HOME}/Makensis.exe">
			<arg line="${win32}/Launcher.nsi"/>
		</exec>

		<exec executable="${env.NSIS_HOME}/Makensis.exe">
			<arg line="${win32}/Installer.nsi"/>
		</exec>

		<move file="${win32}/StardateSystemTraySetup.exe" tofile="${release}/StardateSystemTraySetup-${version}.exe" />
		<delete file="${win32}/StardateSystemTray.exe" />
	</target>

	<target name="test" >
		 <copy todir="${release}/working">
		    <fileset dir="${deb}" excludes="**/*.svn"/>
		  </copy>
	
	</target>


	<!-- Create a Debian package -->
	<target name="Debian" depends="CompileAndJar">
		<echo message="" />
		<echo message="****************************************************************************" />
		<echo message="This task must be run as root.  For example, on Ubuntu: 'sudo ant Debian'" />
		<echo message="After this task, run 'lintian' on the deb file to check for errors/warnings." />
		<echo message="****************************************************************************" />
		<echo message="" />

		<copy todir="${release}/working" preservelastmodified="true">
			<fileset dir="${deb}" excludes="**/*.svn"/>
		</copy>

		<chmod file="${release}/working/DEBIAN/postinst" perm="755"/>
		<chgrp file="${release}/working/DEBIAN/postinst" group="root"/>
		<chown file="${release}/working/DEBIAN/postinst" owner="root"/>

		<chmod file="${release}/working/DEBIAN/postrm" perm="755"/>
		<chgrp file="${release}/working/DEBIAN/postrm" group="root"/>
		<chown file="${release}/working/DEBIAN/postrm" owner="root"/>

		<chmod file="${release}/working/usr/bin/stardatesystemtray" perm="ugo+x"/>

		<copy file="${release}/${jar-filename}" todir="${release}/working/usr/share/stardatesystemtray" preservelastmodified="true" />
		<copy file="${release}/${systemtray-jar-filename}" todir="${release}/working/usr/share/stardatesystemtray" preservelastmodified="true" />
		<copy file="${lib}/joda-time-1.5.2.jar" todir="${release}/working/usr/share/stardatesystemtray" preservelastmodified="true" />

		<copy file="TODO.txt" tofile="${release}/working/usr/share/doc/stardatesystemtray/TODO" preservelastmodified="true" />
		<copy file="${doc}/License.txt" tofile="${release}/working/usr/share/doc/stardatesystemtray/copyright" preservelastmodified="true" />

		<copy file="changelog.Debian" tofile="${release}/working/usr/share/doc/stardatesystemtray/changelog" preservelastmodified="true" />
		<exec executable="gzip">
			<arg line="-9 ${release}/working/usr/share/doc/stardatesystemtray/changelog" />
		</exec>

		<copy file="${img}/stardatesystemtray16x16.xpm" todir="${release}/working/usr/share/pixmaps" preservelastmodified="true" />
		<copy file="${img}/stardatesystemtray32x32.xpm" todir="${release}/working/usr/share/pixmaps" preservelastmodified="true" />	

		<exec executable="dpkg">
			<arg line="--build ${release}/working ${release}/${deb-filename}_${version}_all.deb" />
		</exec>

		<delete dir="${release}/working" />
	</target>


	<!-- Do a full release -->
	<available file="${release}/StardateSystemTraySetup-${version}.exe" property="Win32Ready" />
	<available file="${release}/${deb-filename}_${version}_all.deb" property="DebReady" />

	<condition property="ReadyForRelease">
		<and>
			<available file="${release}/StardateSystemTraySetup-${version}.exe" />
			<available file="${release}/${deb-filename}_${version}_all.deb" />
		</and>
	</condition>

	<target name="ReportWin32Ready" unless="Win32Ready">
		<echo>message="To do a release, the Windows executable must be built!"</echo>
    </target>

	<target name="ReportDebReady" unless="DebReady">
		<echo>message="To do a release, the Debian package must be built!"</echo>
    </target>

	<target name="Release" depends="CompileAndJar, JavaDoc, ReportWin32Ready, ReportDebReady" if="ReadyForRelease">
        <zip destfile="${release}/StardateJavaDoc-${version}.zip" basedir="${javadoc}" />	

        <zip destfile="${release}/StardateJAR-${version}.zip">
            <fileset file="${release}/${jar-filename}"/>
        </zip>

        <zip destfile="${release}/SampleApplet-${version}.zip">
            <fileset file="${release}/${jar-filename}"/>
            <fileset file="${release}/${applet-jar-filename}"/>
            <fileset file="${src}/stardate.html"/>
        </zip>

        <zip destfile="${release}/SampleApplication-${version}.zip">
            <fileset file="${release}/${jar-filename}"/>
            <fileset file="${release}/${application-jar-filename}"/>
        </zip>

        <zip destfile="${release}/StardateSystemTraySource-${version}.zip" basedir="${src}" includes="*.java" />		

		<delete dir="${javadoc}" />
		<delete>
			<fileset dir="${release}">
		    	<include name="**/*.jar"/>
			</fileset>
		</delete>
	</target>


	<target name="Clean">
		<delete dir="${release}" />
	</target>

</project>
