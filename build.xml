<project name="WorldTimeSystemTray" default="CompileAndJar" basedir=".">

	<description>World Time System Tray project build file.</description>

	<property name="version" value="1.4" />

	<property environment="env"/>

	<property name="bin" location="bin" />
	<property name="i18n" location="i18n" />
	<property name="img" location="img" />
	<property name="installer" location="installer" />
	<property name="launcher" location="launcher" />
	<property name="lib" location="lib" />
	<property name="release" location="release" />
	<property name="src" location="src" />

	<condition property="IsWindows" value="true">
		<os family="winnt" />
	</condition>


	<target name="CompileAndJar" description="Compiles and JARs.">
		<delete dir="${bin}" />
		<mkdir dir="${bin}" />

		<javac srcdir="${src}" destdir="${bin}" nowarn="${nowarn}">
			<classpath>
				<pathelement location="${lib}/win32/jRegistryKey.jar" />
			</classpath>
			<compilerarg value="-Xlint:unchecked" />
		</javac>

		<copy todir="${bin}/i18n">
			<fileset dir="${i18n}"/>
		</copy>

		<copy file="${img}/trayicon.gif" todir="${bin}" />

		<manifest file="${bin}/MANIFEST.MF">
			<attribute name="Class-Path" value=". jRegistryKey.jar" />
			<attribute name="Main-Class" value="WorldTimeSystemTray" />
		</manifest>
		<jar jarfile="${bin}/world-time-system-tray.jar" basedir="${bin}" manifest="${bin}/MANIFEST.MF" />
	</target>


	<target name="LauncherAndInstaller" if="IsWindows" depends="CompileAndJar" description="Build the Microsoft Windows installer executable using NSIS.">
		<exec executable="${env.NSIS_HOME}/Makensis.exe">
			<arg line="${launcher}/win32/Launcher.nsi"/>
		</exec>

		<exec executable="${env.NSIS_HOME}/Makensis.exe">
			<arg line="${installer}/win32/Installer.nsi"/>
		</exec>
		<mkdir dir="${release}" />
		<move file="${installer}/win32/WorldTimeSystemTraySetup.exe" tofile="${release}/WorldTimeSystemTraySetup-${version}.exe" /> 

		<delete file="${launcher}/win32/WorldTimeSystemTray.exe" />
	</target>


	<target name="Release" depends="LauncherAndInstaller" description="Releases the Jar file and source code.">
        <zip destfile="${release}/WorldTimeSystemTrayJAR-${version}.zip">
            <fileset file="${bin}/world-time-system-tray.jar"/>
        </zip>

        <zip destfile="${release}/Source-${version}.zip" basedir="${src}" includes="*.java" />		
    </target>

</project>
