<project name="StardateSystemTray" default="CompileAndJar" basedir=".">

	<description>Stardate and Stardate System Tray project build file.</description>

	<property name="version" value="1.5" />

	<property environment="env"/>

	<property name="bin" location="bin" />
	<property name="i18n" location="i18n" />
	<property name="img" location="img" />
	<property name="installer" location="installer" />
	<property name="javadoc" location="javadoc" />
	<property name="launcher" location="launcher" />
	<property name="lib" location="lib" />
	<property name="release" location="release" />
	<property name="src" location="src" />

	<condition property="IsWindows" value="true">
		<os family="winnt" />
	</condition>


	<target name="CompileAndJar" description="Compiles and JARs the stardate back-end, example programs and the system tray front end.">
		<delete dir="${bin}" />
		<mkdir dir="${bin}" />

		<javac srcdir="${src}" destdir="${bin}" nowarn="${nowarn}">
			<classpath>
				<pathelement location="${lib}/joda-time-1.5.2.jar" />								
				<pathelement location="${lib}/win32/jRegistryKey.jar" />
			</classpath>
			<compilerarg value="-Xlint:unchecked" />
		</javac>

		<jar jarfile="${bin}/stardate.jar" basedir="${bin}" includes="Stardate.class StardateException*.class" />

		<jar jarfile="${bin}/stardate-applet.jar" basedir="${bin}" includes="StardateApplet*.class" />

		<copy todir="${bin}/i18n">
			<fileset dir="${i18n}"/>
		</copy>

		<copy file="${img}/trayicon.gif" todir="${bin}" />

		<manifest file="${bin}/MANIFEST.MF">
			<attribute name="Class-Path" value=". stardate.jar" />
			<attribute name="Main-Class" value="StardateConverter" />
		</manifest>
		<jar jarfile="${bin}/stardate-converter.jar" basedir="${bin}" includes="StardateConverter.class trayicon.gif" manifest="${bin}/MANIFEST.MF" />

		<manifest file="${bin}/MANIFEST.MF">
			<attribute name="Class-Path" value=". stardate.jar joda-time-1.5.2.jar jRegistryKey.jar" />
			<attribute name="Main-Class" value="StardateSystemTray" />
		</manifest>
		<jar jarfile="${bin}/stardate-system-tray.jar" basedir="${bin}" includes=" i18n/* Messages.class PopupMenu.class Properties.class StardateSystemTray.class SystemStart.class TrayIcon.class trayicon.gif" manifest="${bin}/MANIFEST.MF" />

	</target>


	<target name="LauncherAndInstaller" if="IsWindows" depends="CompileAndJar" description="Build the Microsoft Windows launcher and installer executables using NSIS.">
		<exec executable="${env.NSIS_HOME}/Makensis.exe">
			<arg line="${launcher}/win32/Launcher.nsi"/>
		</exec>

		<exec executable="${env.NSIS_HOME}/Makensis.exe">
			<arg line="${installer}/win32/Installer.nsi"/>
		</exec>
		<mkdir dir="${release}" />
		<move file="${installer}/win32/StardateSystemTraySetup.exe" tofile="${release}/StardateSystemTraySetup-${version}.exe" /> 

		<delete file="${launcher}/win32/StardateSystemTray.exe" />
	</target>


	<target name="JavaDoc" description="Create Javadoc for the Stardate API.">
		<property name="windowtitle" value="Stardate v1.0 API Specification" />
		<property name="doctitle" value="Stardate v1.0 API Specification" />
		<property name="header" value="Stardate v1.0 API Specification" />
		<delete dir="${javadoc}" />
		<mkdir dir="${javadoc}" />
		<javadoc 
			sourcefiles="${src}/Stardate.java,${src}/StardateException.java" 
			packagenames="*.*" 
			destdir="${javadoc}" 
			author="true" 
			version="true" 
			use="true" 
			splitindex="true" 
			overview="${src}/overview.html" 
			windowtitle="${windowtitle}" 
			header="${header}" 
			doctitle="${doctitle}"
		>
		</javadoc>
	</target>


	<target name="Release" depends="LauncherAndInstaller, JavaDoc" description="Releases the Jar files, installer, JavaDoc and source code.">
        <zip destfile="${release}/StardateJavaDoc-${version}.zip" basedir="${javadoc}" />	

        <zip destfile="${release}/SampleApplet-${version}.zip">
            <fileset file="${bin}/stardate.jar"/>
            <fileset file="${bin}/stardate-applet.jar"/>
            <fileset file="${src}/stardate.html"/>
        </zip>

        <zip destfile="${release}/SampleApplication-${version}.zip">
            <fileset file="${bin}/stardate.jar"/>
            <fileset file="${bin}/stardate-converter.jar"/>
        </zip>

        <zip destfile="${release}/StardateJAR-${version}.zip">
            <fileset file="${bin}/stardate.jar"/>
        </zip>

        <zip destfile="${release}/StardateSystemTray-${version}.zip">
            <fileset file="${bin}/stardate.jar"/>
            <fileset file="${bin}/stardate-system-tray.jar"/>
        </zip>

        <zip destfile="${release}/Source-${version}.zip" basedir="${src}" includes="*.java" />		
    </target>

</project>
